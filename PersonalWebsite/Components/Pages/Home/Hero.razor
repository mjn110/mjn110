<header class="hero">
    <div class="hero__bg">
        <div class="hero__orb hero__orb--1"></div>
        <div class="hero__orb hero__orb--2"></div>
        <div class="hero__orb hero__orb--3"></div>
        <div class="hero__grid"></div>
    </div>
    <div class="hero__content section">
        <div class="badge">
            <span class="badge__dot"></span>
            <span>@Availability</span>
        </div>
        <h1>@Firstname<br><span class="gradient-text">@Lastname</span></h1>
        <p class="hero__title">@Position</p>
        <p class="hero__summary">@Summary</p>
        <div class="contact-row">
            <span class="contact-item">
                <span class="contact-item__icon"><svg class="icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg></span>
                @Location
            </span>
            <a href="mailto:mjn220@gmail.com" class="contact-item">
                <span class="contact-item__icon"><svg class="icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg></span>
                @Email
            </a>
            <a href="tel:+4407904114515" class="contact-item">
                <span class="contact-item__icon"><svg class="icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg></span>
                @Phone
            </a>
        </div>
        <div class="social-links">
            <a href="https://github.com/mjn110" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
                <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" /></svg>
                GitHub
            </a>
            <a href="https://www.linkedin.com/in/mj-najafi" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
                <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" /></svg>
                LinkedIn
            </a>
        </div>
    </div>
</header>

@code {
    public string Availability { get; set; } = string.Empty;
    public string Firstname { get; set; } = "Muhammad";
    public string Lastname { get; set; } = "Najafi";
    public string Position { get; set; } = string.Empty;
    public string Summary { get; set; } = string.Empty;
    public string Email { get; set; } = string.Empty;
    public string Phone { get; set; } = string.Empty;
    public string Location { get; set; } = string.Empty;

        protected override Task OnInitializedAsync()
    {
        SetAvailability();
        SetPosition();
        SetSummary();
        SetEmail();
        SetPhone();
        SetLocation();
        return base.OnInitializedAsync();
    }

    void SetAvailability()
    {
            Availability = "Available for opportunities";
    }

    void SetPosition()
    {
        Position = "Senior Software Engineer";
    }

    void SetSummary()
    {
        Summary = "A solutions developer with 5+ years' experience in C# and ASP.NET Core with strong expertise in Blazor for building scalable apps. Focused on clean code, performance optimization, and secure implementation.";
    }

    void SetEmail()
    {
        Email = "mjn220@gmail.com";
    }

    void SetPhone()
    {
        Phone = "07904114515";
    }

    void SetLocation()
    {
        Location = "Birmingham, UK";
    }
}
