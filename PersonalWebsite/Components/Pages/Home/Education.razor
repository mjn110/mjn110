<!-- ===== EDUCATION ===== -->
<section class="section section--alt">
    <div class="bg-blob" style="right:0;top:33%;width:24rem;height:24rem;background:hsl(280,85%,60%,0.05);"></div>
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-header__label">
                    <span class="section-header__icon" style="background:hsl(280,85%,60%,0.1);color:var(--accent);"><svg class="icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c0 1 4 3 6 3s6-2 6-3v-5" /></svg></span>
                    <span class="section-header__tag" style="color:var(--accent);">Academic</span>
                </div>
                <h2>Education</h2>
            </div>
            <p class="section-header__desc">Continuous learning from software engineering to artificial intelligence</p>
        </div>
        <div class="grid-2">

            <div class="card">
                <div class="card__overlay"></div>
                <div class="card__corner"></div>
                <div class="card__inner">
                    <div class="card__header">
                        <div>
                            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.75rem;">
                                <span class="card__title">Postgraduate in Artificial Intelligence</span>
                                <span class="card__badge">2024 – 2025</span>
                            </div>
                            <p class="card__subtitle">Aston University</p>
                        </div>
                        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
                    </div>
                    <div class="card__body"><em style="color:var(--muted-fg);opacity:0.7;">Hover to see achievements</em></div>
                    <div class="card__expandable">
                        <div class="card__expandable-inner">
                            <div class="card__expandable-content">
                                <ul class="detail-list">
                                    <li class="detail-item"><span class="detail-dot" style="background:var(--accent);"></span><span>Built an agent-based navigation system for game NPCs in Unreal Engine 5</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card__overlay"></div>
                <div class="card__corner"></div>
                <div class="card__inner">
                    <div class="card__header">
                        <div>
                            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.75rem;">
                                <span class="card__title">Bachelor's in Software Engineering</span>
                                <span class="card__badge">2013 – 2017</span>
                            </div>
                            <p class="card__subtitle">Shahab Danesh University</p>
                        </div>
                        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
                    </div>
                    <div class="card__body"><em style="color:var(--muted-fg);opacity:0.7;">Hover to see achievements</em></div>
                    <div class="card__expandable">
                        <div class="card__expandable-inner">
                            <div class="card__expandable-content">
                                <ul class="detail-list">
                                    <li class="detail-item"><span class="detail-dot" style="background:var(--accent);"></span><span>Participated in inter-universities programming contest, achieving fifth place</span></li>
                                    <li class="detail-item"><span class="detail-dot" style="background:var(--accent);"></span><span>Taught C# and C++ console apps to students, helping with 50+ assessments</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

