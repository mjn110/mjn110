@using PersonalWebsite.Components.Pages.Home.Assets
<section class="section">
    <div class="bg-blob" style="left:0;top:50%;transform:translateY(-50%);width:18rem;height:18rem;background:hsl(220,90%,56%,0.05);"></div>
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-header__label">
                    <span class="section-header__icon"><svg class="icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2" /><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" /></svg></span>
                    <span class="section-header__tag">Career</span>
                </div>
                <h2>Work Experience</h2>
            </div>
            <p class="section-header__desc">Building scalable solutions across multiple industries and technologies</p>
        </div>
        <div class="grid-2">

            <ExperienceCard Role="Senior Software Developer" Duration="6 Months" Company="Enterprise AI Academy" From="Jul 2025" To="Dec 2025" Summary="Constructed training AI system and dashboards for business monitoring and data analysis.">
                <Options>
                    <li class="detail-item"><span class="detail-dot"></span><span>Combined ML models and software to build data-driven dashboard for analytical purposes</span></li>
                </Options>
            </ExperienceCard>

            <ExperienceCard Role="Senior Software Developer" Duration="2 Years" Company="Vira Development Group" From="Jul 2021" To="Dec 2023" Summary="Led backend development team for creating a high-scale social media message assistant.">
                <Options>
                    <li class="detail-item"><span class="detail-dot"></span><span>Increased revenue by replacing frontend tech with Blazor, downsizing team from 7 to 4 members</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Proposed IoC design principle adoption, reducing code duplication by 50%</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Built frontend component library in Blazor from scratch, improving scalability</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Applied Clean Architecture and SOLID principles for modular components</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Organized CI/CD pipelines using Azure DevOps, GitHub Actions, and Docker</span></li>
                </Options>
            </ExperienceCard>

            <ExperienceCard Role="Software Developer" Duration="2 Years" Company="Vira Development Group" From="Jul 2019" To="Jun 2021" Summary="Designed cloud-native applications using Azure, optimizing security and performance.">
                <Options>
                    <li class="detail-item"><span class="detail-dot"></span><span>Designed secure web applications with OAuth 2.0, JWT, and claim-based security</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Modernized legacy elements into Blazor-based solutions</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Created reusable UI elements using JavaScript</span></li>
                </Options>
            </ExperienceCard>

            <ExperienceCard Role=".NET Developer" Duration="1 Year" Company="Daymond" From="Mar 2018" To="Mar 2019" Summary="Developed web applications and marketing system design for pharmaceutical company.">
                <Options>
                    <li class="detail-item"><span class="detail-dot"></span><span>Developed pharmaceutical company marketing system design</span></li>
                    <li class="detail-item"><span class="detail-dot"></span><span>Built .NET web form applications focusing on OOP and data integration</span></li>
                </Options>
            </ExperienceCard>

        </div>
    </div>
</section>

