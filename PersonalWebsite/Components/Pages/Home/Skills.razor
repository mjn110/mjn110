<section class="section section--alt">
    <div class="bg-blob" style="right:0;top:25%;width:18rem;height:18rem;background:hsl(220,90%,56%,0.05);"></div>
    <div class="bg-blob" style="left:0;bottom:25%;width:24rem;height:24rem;background:hsl(280,85%,60%,0.05);"></div>
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-header__label">
                    <span class="section-header__icon"><svg class="icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" /></svg></span>
                    <span class="section-header__tag">Expertise</span>
                </div>
                <h2>Technologies & Skills</h2>
            </div>
            <p class="section-header__desc">A comprehensive toolkit for building modern applications</p>
        </div>
        <div class="grid-4">

            <div class="card">
                <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
                    <span class="card__title" style="font-size:1rem;">Programming Languages</span>
                    <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
                </div>
                <div class="tag-list">
                    <span class="tag">C#</span><span class="tag">C++</span><span class="tag">SQL</span>
                    <span class="tag tag--accent">+3 more</span>
                </div>
                <div class="card__expandable">
                    <div class="card__expandable-inner">
                        <div class="card__expandable-content">
                            <div class="tag-list"><span class="tag tag--accent">VB.NET</span><span class="tag tag--accent">JavaScript</span><span class="tag tag--accent">TypeScript</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
                <span class="card__title" style="font-size:1rem;">Frontend Development</span>
                <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
            </div>
            <div class="tag-list">
                <span class="tag">Blazor</span><span class="tag">Razor</span><span class="tag">CSS</span>
                <span class="tag tag--accent">+1 more</span>
            </div>
            <div class="card__expandable">
                <div class="card__expandable-inner">
                    <div class="card__expandable-content">
                        <div class="tag-list"><span class="tag tag--accent">Bootstrap</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <span class="card__title" style="font-size:1rem;">Backend & Cloud</span>
            <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
        </div>
        <div class="tag-list">
            <span class="tag">ASP.NET Core</span><span class="tag">Azure</span><span class="tag">Azure AI</span>
            <span class="tag tag--accent">+2 more</span>
        </div>
        <div class="card__expandable">
            <div class="card__expandable-inner">
                <div class="card__expandable-content">
                    <div class="tag-list"><span class="tag tag--accent">REST APIs</span><span class="tag tag--accent">WCF/SOAP</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <span class="card__title" style="font-size:1rem;">Databases</span>
        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
    </div>
    <div class="tag-list">
        <span class="tag">SQL Server</span><span class="tag">PostgreSQL</span><span class="tag">EF Core</span>
        <span class="tag tag--accent">+1 more</span>
    </div>
    <div class="card__expandable">
        <div class="card__expandable-inner">
            <div class="card__expandable-content">
                <div class="tag-list"><span class="tag tag--accent">LINQ</span></div>
            </div>
        </div>
    </div>
</div>
</div>

<div class="card">
    <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <span class="card__title" style="font-size:1rem;">Security</span>
        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
    </div>
    <div class="tag-list">
        <span class="tag">OAuth 2.0</span><span class="tag">JWT</span><span class="tag">Claim-Based</span>
        <span class="tag tag--accent">+2 more</span>
    </div>
    <div class="card__expandable">
        <div class="card__expandable-inner">
            <div class="card__expandable-content">
                <div class="tag-list"><span class="tag tag--accent">Role-Based Auth</span><span class="tag tag--accent">IIS Best Practices</span></div>
            </div>
        </div>
    </div>
</div>
</div>

<div class="card">
    <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <span class="card__title" style="font-size:1rem;">DevOps & Tools</span>
        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
    </div>
    <div class="tag-list">
        <span class="tag">Azure DevOps</span><span class="tag">Git</span><span class="tag">Docker</span>
        <span class="tag tag--accent">+3 more</span>
    </div>
    <div class="card__expandable">
        <div class="card__expandable-inner">
            <div class="card__expandable-content">
                <div class="tag-list"><span class="tag tag--accent">Kubernetes</span><span class="tag tag--accent">CI/CD</span><span class="tag tag--accent">GitHub Actions</span></div>
            </div>
        </div>
    </div>
</div>
</div>

<div class="card">
    <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <span class="card__title" style="font-size:1rem;">Testing</span>
        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
    </div>
    <div class="tag-list">
        <span class="tag">Unit Testing</span><span class="tag">TDD</span><span class="tag">xUnit</span>
        <span class="tag tag--accent">+1 more</span>
    </div>
    <div class="card__expandable">
        <div class="card__expandable-inner">
            <div class="card__expandable-content">
                <div class="tag-list"><span class="tag tag--accent">bUnit</span></div>
            </div>
        </div>
    </div>
</div>
</div>

<div class="card">
    <div class="card__overlay"></div><div class="card__corner"></div><div class="card__inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <span class="card__title" style="font-size:1rem;">AI & ML</span>
        <div class="card__chevron"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg></div>
    </div>
    <div class="tag-list">
        <span class="tag">Machine Learning</span><span class="tag">AI Integration</span><span class="tag">Copilot</span>
    </div>
</div>
</div>

</div>
</div>
</section>

